{
  "name": "trinity-agent",
  "version": "1.0.0",
  "description": "Agente local Windows para máquina fiscal y tickets térmicos",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "package": "pkg dist/server.js --targets node18-win-x64 --output trinity-agent.exe"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "pkg": "^5.8.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^18.0.0"
  }
}
