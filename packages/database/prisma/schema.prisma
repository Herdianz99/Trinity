generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  SUPERVISOR
  CASHIER
  SELLER
  WAREHOUSE
  BUYER
  ACCOUNTANT
  AUDITOR
}

enum IvaType {
  EXEMPT
  REDUCED
  GENERAL
  SPECIAL
}

enum MovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  COUNT_ADJUST
  RETURN_IN
  RETURN_OUT
  REPLACEMENT_IN
  REPLACEMENT_OUT
}

enum NoteType {
  NCV
  NDV
  NCC
  NDC
}

enum NoteOrigin {
  MERCHANDISE
  MANUAL
}

enum NoteStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum TransferStatus {
  PENDING
  APPROVED
  CANCELLED
}

enum CountStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  CANCELLED
}

enum PurchaseStatus {
  PENDING
  PROCESSED
  CANCELLED
}

enum RetentionStatus {
  PENDING
  ISSUED
  CANCELLED
}

enum PermissionKey {
  OVERRIDE_PRICE
  RETURN_INVOICE
  CREDIT_NOTE_SALE
  DEBIT_NOTE_SALE
  RETURN_PURCHASE
  CREDIT_NOTE_PURCHASE
  DEBIT_NOTE_PURCHASE
  MANAGE_EXPENSES
}

enum SerieType {
  SALES
  PURCHASES
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum AdjustmentStatus {
  DRAFT
  PROCESSED
  CANCELLED
}

enum AdjustmentType {
  IN
  OUT
}

enum SupplierType {
  JURIDICA
  NATURAL_RESIDENTE
  NATURAL_NO_RESIDENTE
}

enum InvoicePaymentType {
  CASH
  CREDIT
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL_RETURN
  RETURNED
  CANCELLED
}

enum InvoiceType {
  SALE
  DEBIT_NOTE
  CREDIT_NOTE
}

// PaymentMethod is now a table (see model below) instead of an enum

enum ReceivableType {
  CUSTOMER_CREDIT
  FINANCING_PLATFORM
  MANUAL
}

enum CustomerAdvanceStatus {
  AVAILABLE
  PARTIAL
  CONSUMED
}

enum SupplierAdvanceStatus {
  AVAILABLE
  PARTIAL
  CONSUMED
}

enum ReceivableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentScheduleStatus {
  DRAFT
  APPROVED
  EXECUTED
  CANCELLED
}

enum ReceiptType {
  COLLECTION
  PAYMENT
}

enum ReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum ReceiptItemType {
  RECEIVABLE
  PAYABLE
  DIFFERENTIAL
  CREDIT_NOTE
  DEBIT_NOTE
  IVA_RETENTION
  SALES_IVA_RETENTION
}

enum DynamicKeyPerm {
  DELETE_CREDIT_NOTE_SALE
  DELETE_DEBIT_NOTE_SALE
  DELETE_CREDIT_NOTE_PURCHASE
  DELETE_DEBIT_NOTE_PURCHASE
  DELETE_RECEIPT_COLLECTION
  DELETE_RECEIPT_PAYMENT
  DELETE_RECEIVABLE
  DELETE_PAYABLE
  DELETE_EXPENSE
  MODIFY_PRODUCT_PRICE
  CANCEL_CASH_SESSION
  CHANGE_EXCHANGE_RATE
  MANUAL_STOCK_ADJUSTMENT
  GIVE_DISCOUNT
  ALLOW_CREDIT_INVOICE
  MANUAL_CASH_MOVEMENT
}

enum CashMovementType {
  INCOME
  EXPENSE
}

// ============================================
// CONFIG
// ============================================

model CompanyConfig {
  id                      String   @id @default("singleton")
  companyName             String   @default("Trinity")
  rif                     String?
  address                 String?
  phone                   String?
  email                   String?
  bregaGlobalPct          Float    @default(0)
  defaultGananciaPct      Float    @default(0)
  defaultGananciaMayorPct Float    @default(0)
  defaultWarehouseId      String?
  invoicePrefix           String   @default("FAC")
  creditAuthPassword      String?
  quotationValidityDays   Int      @default(30)
  overdueWarningDays      Int      @default(3)
  ivaRetentionPct         Float    @default(75)
  islrRetentionPct        Float    @default(0)
  isIGTFContributor       Boolean  @default(false)
  igtfPct                 Float    @default(3)
  fiscalCreditCode        String   @default("10")
  allowNegativeStock      Boolean  @default(true)
  defaultCustomerId       String?
  logo                    String?  @db.Text
  stampImage              String?  @db.Text
  retentionProvidencia    String   @default("SNAT/2025/000054")
  retentionNextNumber     Int      @default(1)
  islrRetentionNextNumber Int      @default(1)
  unidadTributaria        Float    @default(43)
  receivableNextNumber    Int      @default(1)
  payableNextNumber       Int      @default(1)
  updatedAt               DateTime @updatedAt
}

// ============================================
// TASA DE CAMBIO
// ============================================

model ExchangeRate {
  id          String             @id @default(cuid())
  rate        Float
  date        DateTime           @unique @db.Date
  source      ExchangeRateSource @default(MANUAL)
  createdById String?
  createdAt   DateTime           @default(now())
}

enum ExchangeRateSource {
  BCV
  MANUAL
}

// ============================================
// AUTH & USUARIOS
// ============================================

model User {
  id                  String              @id @default(cuid())
  name                String
  email               String              @unique
  password            String
  role                UserRole
  isActive            Boolean             @default(true)
  mustChangePassword  Boolean             @default(true)
  lastLoginAt         DateTime?
  permissions         UserPermission[]
  sessionsOpened      CashSession[]       @relation("SessionOpenedBy")
  sessionsClosed      CashSession[]       @relation("SessionClosedBy")
  seller              Seller?
  invoicesAsCashier   Invoice[]           @relation("InvoiceCashier")
  expenses            Expense[]
  cashMovements       CashMovement[]
  paymentSchedules    PaymentSchedule[]
  dynamicKeys         DynamicKey[]
  purchaseBills       PurchaseOrder[]     @relation("PurchaseBillResponsible")
  purchaseBookEntries PurchaseBookEntry[] @relation("PurchaseBookEntries")
  salesBookEntries    SalesBookEntry[]    @relation("SalesBookEntries")
  retentionVouchers       RetentionVoucher[]      @relation("RetentionVoucherCreator")
  islrRetentionVouchers   IslrRetentionVoucher[]  @relation("IslrRetentionVoucherCreator")
  customerAdvances    CustomerAdvance[]   @relation("AdvanceCreator")
  supplierAdvances    SupplierAdvance[]   @relation("SupplierAdvanceCreator")
  receivablesCreated  Receivable[]        @relation("ReceivableCreator")
  payablesCreated     Payable[]           @relation("PayableCreator")
  zReports            ZReport[]           @relation("ZReportCreator")
  customerIvaRetentions   CustomerIvaRetention[] @relation("CustomerIvaRetentionCreator")
  lostSales           LostSale[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model UserPermission {
  id            String        @id @default(cuid())
  userId        String
  permissionKey PermissionKey
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  @@unique([userId, permissionKey])
}

model RolePermission {
  id        String   @id @default(cuid())
  role      UserRole @unique
  modules   String[]
  updatedAt DateTime @updatedAt
}

// ============================================
// CLAVES DINAMICAS DE AUTORIZACION
// ============================================

model DynamicKey {
  id          String                 @id @default(cuid())
  name        String
  keyHash     String
  isActive    Boolean                @default(true)
  permissions DynamicKeyPermission[]
  logs        DynamicKeyLog[]
  createdById String
  createdBy   User                   @relation(fields: [createdById], references: [id])
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model DynamicKeyPermission {
  id           String         @id @default(cuid())
  dynamicKeyId String
  dynamicKey   DynamicKey     @relation(fields: [dynamicKeyId], references: [id], onDelete: Cascade)
  permission   DynamicKeyPerm

  @@unique([dynamicKeyId, permission])
}

model DynamicKeyLog {
  id           String         @id @default(cuid())
  dynamicKeyId String
  dynamicKey   DynamicKey     @relation(fields: [dynamicKeyId], references: [id], onDelete: Cascade)
  permission   DynamicKeyPerm
  action       String
  entityType   String?
  entityId     String?
  createdAt    DateTime       @default(now())
}

// ============================================
// VENDEDORES
// ============================================

model Seller {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  phone           String?
  isActive        Boolean   @default(true)
  monthlyGoalUsd  Float     @default(0)
  userId          String?   @unique
  user            User?     @relation(fields: [userId], references: [id])
  invoices        Invoice[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// AREAS DE IMPRESION
// ============================================

model PrintArea {
  id          String     @id @default(cuid())
  name        String
  description String?
  isActive    Boolean    @default(true)
  categories  Category[]
  printJobs   PrintJob[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ============================================
// CATALOGO
// ============================================

model Category {
  id                String     @id @default(cuid())
  name              String
  code              String?    @unique
  lastProductNumber Int        @default(0)
  commissionPct     Float      @default(0)
  printAreaId       String?
  printArea         PrintArea? @relation(fields: [printAreaId], references: [id])
  parentId          String?
  parent            Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children          Category[] @relation("SubCategories")
  products          Product[]
  createdAt         DateTime   @default(now())
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
}

model Supplier {
  id                String             @id @default(cuid())
  name              String
  rif               String?
  phone             String?
  email             String?
  address           String?
  contactName       String?
  isRetentionAgent  Boolean            @default(false)
  supplierType      SupplierType?
  islrConceptId     String?
  islrConcept       IslrRetentionType? @relation("SupplierIslrConcept", fields: [islrConceptId], references: [id])
  isActive          Boolean            @default(true)
  products          Product[]
  purchaseOrders    PurchaseOrder[]
  payables          Payable[]
  receipts          Receipt[]
  ivaRetentions     IvaRetention[]
  retentionVouchers RetentionVoucher[]
  islrRetentionVouchers IslrRetentionVoucher[]
  advances              SupplierAdvance[]
  inventoryAdjustments  InventoryAdjustment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// ============================================
// PRODUCTOS
// ============================================

model Product {
  id               String                   @id @default(cuid())
  code             String                   @unique
  barcode          String?                  @unique
  supplierRef      String?
  name             String
  description      String?
  categoryId       String?
  category         Category?                @relation(fields: [categoryId], references: [id])
  brandId          String?
  brand            Brand?                   @relation(fields: [brandId], references: [id])
  supplierId       String?
  supplier         Supplier?                @relation(fields: [supplierId], references: [id])
  isService        Boolean                  @default(false)
  purchaseUnit     String                   @default("UNIT")
  saleUnit         String                   @default("UNIT")
  conversionFactor Float                    @default(1)
  costUsd          Float                    @default(0)
  bregaApplies     Boolean                  @default(true)
  manualPrice      Boolean                  @default(false)
  gananciaPct      Float                    @default(0)
  gananciaMayorPct Float                    @default(0)
  ivaType          IvaType                  @default(GENERAL)
  priceDetal       Float                    @default(0)
  priceMayor       Float                    @default(0)
  minStock         Float                    @default(0)
  isActive         Boolean                  @default(true)
  searchVector     Unsupported("tsvector")?
  stock            Stock[]
  movements        StockMovement[]
  purchaseItems    PurchaseOrderItem[]
  transferItems    TransferItem[]
  countItems       InventoryCountItem[]
  adjustmentItems  InventoryAdjustmentItem[]
  replacementOutItems InventoryReplacementItem[] @relation("ReplacementOut")
  replacementInItems  InventoryReplacementItem[] @relation("ReplacementIn")
  lostSales        LostSale[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

// ============================================
// INVENTARIO
// ============================================

model Warehouse {
  id              String           @id @default(cuid())
  name            String
  location        String?
  isDefault       Boolean          @default(false)
  isActive        Boolean          @default(true)
  stock           Stock[]
  movements       StockMovement[]
  transfersFrom   Transfer[]       @relation("TransferFrom")
  transfersTo     Transfer[]       @relation("TransferTo")
  inventoryCounts      InventoryCount[]
  inventoryAdjustments InventoryAdjustment[]
  inventoryReplacements InventoryReplacement[]
  purchaseBills        PurchaseOrder[]  @relation("PurchaseBillWarehouse")
  createdAt       DateTime         @default(now())
}

model Stock {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float     @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model StockMovement {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  type        MovementType
  quantity    Float
  costUsd     Float        @default(0)
  stockAfter  Float        @default(0)
  reason      String?
  reference   String?
  sourceType  String?      // SALE_INVOICE | PURCHASE_ORDER | INVENTORY_ADJUSTMENT | INVENTORY_COUNT | CREDIT_DEBIT_NOTE | TRANSFER | REPLACEMENT
  sourceId    String?      // ID real del documento origen, para auditar (abrir el documento desde el movimiento)
  createdById String
  createdAt   DateTime     @default(now())
}

// ============================================
// TRANSFERENCIAS
// ============================================

model Transfer {
  id              String         @id @default(cuid())
  number          String?        @unique // TRF-0001 (correlativo)
  fromWarehouseId String
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus @default(PENDING)
  notes           String?
  items           TransferItem[]
  createdById     String
  approvedById    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model TransferItem {
  id         String   @id @default(cuid())
  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
}

// ============================================
// CONTEO FISICO
// ============================================

model InventoryCount {
  id           String               @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse            @relation(fields: [warehouseId], references: [id])
  status       CountStatus          @default(DRAFT)
  notes        String?
  items        InventoryCountItem[]
  createdById  String
  approvedById String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model InventoryCountItem {
  id               String         @id @default(cuid())
  inventoryCountId String
  inventoryCount   InventoryCount @relation(fields: [inventoryCountId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  systemQuantity   Float
  countedQuantity  Float?
  difference       Float?

  @@unique([inventoryCountId, productId])
}

model InventoryAdjustment {
  id            String               @id @default(cuid())
  warehouseId   String
  warehouse     Warehouse            @relation(fields: [warehouseId], references: [id])
  type          AdjustmentType
  status        AdjustmentStatus     @default(DRAFT)
  description   String?
  customerId    String?
  customer      Customer?            @relation(fields: [customerId], references: [id])
  supplierId    String?
  supplier      Supplier?            @relation(fields: [supplierId], references: [id])
  items         InventoryAdjustmentItem[]
  createdById   String
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model InventoryAdjustmentItem {
  id                    String              @id @default(cuid())
  inventoryAdjustmentId String
  inventoryAdjustment   InventoryAdjustment @relation(fields: [inventoryAdjustmentId], references: [id])
  productId             String
  product               Product             @relation(fields: [productId], references: [id])
  quantity              Float               @default(0)

  @@unique([inventoryAdjustmentId, productId])
}

// ============================================
// REEMPLAZOS DE INVENTARIO
// Canje: sale un articulo y entra otro en su lugar (ej. 2 rollos -> 200 metros)
// ============================================

enum ReplacementStatus {
  DRAFT
  PROCESSED
  CANCELLED
}

model InventoryReplacement {
  id            String                     @id @default(cuid())
  number        String                     @unique // REP-0001
  warehouseId   String
  warehouse     Warehouse                  @relation(fields: [warehouseId], references: [id])
  date          DateTime // fecha-calendario elegida por el usuario (medianoche UTC, date-only)
  notes         String? // observacion
  status        ReplacementStatus          @default(DRAFT)
  items         InventoryReplacementItem[]
  createdById   String
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
}

model InventoryReplacementItem {
  id            String               @id @default(cuid())
  replacementId String
  replacement   InventoryReplacement @relation(fields: [replacementId], references: [id])
  // Articulo que SALE
  outProductId  String
  outProduct    Product              @relation("ReplacementOut", fields: [outProductId], references: [id])
  outQuantity   Float                @default(0)
  outCostUsd    Float                @default(0) // costo congelado al procesar
  // Articulo que ENTRA
  inProductId   String
  inProduct     Product              @relation("ReplacementIn", fields: [inProductId], references: [id])
  inQuantity    Float                @default(0)
  inCostUsd     Float                @default(0) // costo congelado al procesar
}

// ============================================
// COMPRAS
// ============================================

model PurchaseOrder {
  id                    String                 @id @default(cuid())
  number                String                 @unique
  supplierId            String
  supplier              Supplier               @relation(fields: [supplierId], references: [id])
  status                PurchaseStatus         @default(PENDING)
  invoiceDate           DateTime?
  receivedDate          DateTime?
  currency              String                 @default("USD")
  totalUsd              Float                  @default(0)
  totalBs               Float                  @default(0)
  exchangeRate          Float                  @default(1)
  surchargeUsd          Float                  @default(0)
  surchargeDistribution String                 @default("PROPORTIONAL")
  totalWithSurchargeUsd Float                  @default(0)
  isFiscal              Boolean                @default(true)
  serieId               String?
  serie                 Serie?                 @relation(fields: [serieId], references: [id])
  isCredit              Boolean                @default(false)
  creditDays            Int                    @default(0)
  supplierControlNumber String?
  islrRetentionPct      Float?
  islrRetentionUsd      Float?
  islrRetentionBs       Float?
  notes                 String?
  receivedAt            DateTime?
  items                 PurchaseOrderItem[]
  payables              Payable[]
  creditDebitNotes      CreditDebitNote[]
  ivaRetentions         IvaRetention[]
  retentionVoucherLines     RetentionVoucherLine[]
  islrRetentionVoucherLines IslrRetentionVoucherLine[]
  purchaseBookEntries       PurchaseBookEntry[]
  createdById           String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Purchase Bill fields
  purchaseNumber         Int        @default(0)
  supplierSerialNumber   String?
  supplierInvoiceNumber  String?
  discountGlobalPct      Float      @default(0)
  discountGlobalUsd      Float      @default(0)
  discountGlobalBs       Float      @default(0)
  subtotalUsd            Float      @default(0)
  subtotalBs             Float      @default(0)
  exemptAmountUsd        Float      @default(0)
  exemptAmountBs         Float      @default(0)
  taxableBaseUsd         Float      @default(0)
  taxableBaseBs          Float      @default(0)
  totalIvaUsd            Float      @default(0)
  totalIvaBs             Float      @default(0)
  totalSurchargeUsd      Float      @default(0)
  totalSurchargeBs       Float      @default(0)
  retentionVoucherNumber String?
  responsibleId          String?
  responsible            User?      @relation("PurchaseBillResponsible", fields: [responsibleId], references: [id])
  processedAt            DateTime?
  warehouseId            String?
  warehouse              Warehouse? @relation("PurchaseBillWarehouse", fields: [warehouseId], references: [id])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Float
  costUsd         Float
  costBs          Float         @default(0)
  totalUsd        Float
  totalBs         Float         @default(0)
  receivedQty     Float         @default(0)
  discountPct     Float         @default(0)
  discountUsd     Float         @default(0)
  discountBs      Float         @default(0)
  netCostUsd      Float         @default(0)
  netCostBs       Float         @default(0)
  landedCostUsd   Float         @default(0)
  landedCostBs    Float         @default(0)
}

// ============================================
// CLIENTES
// ============================================

model Customer {
  id           String       @id @default(cuid())
  name         String
  documentType String       @default("V")
  rif          String?
  phone        String?
  email        String?
  address      String?
  creditLimit  Float        @default(0)
  creditDays   Int          @default(0)
  isDefault    Boolean      @default(false)
  isActive     Boolean      @default(true)
  isSpecialTaxpayer Boolean @default(false)
  isGroupCompany    Boolean @default(false) // Empresa del grupo: sus facturas no comisionan
  invoices     Invoice[]
  quotations   Quotation[]
  receivables  Receivable[]
  receipts     Receipt[]
  advances              CustomerAdvance[]
  inventoryAdjustments  InventoryAdjustment[]
  ivaRetentions         CustomerIvaRetention[]
  lostSales             LostSale[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ============================================
// VENTAS PERDIDAS (demanda insatisfecha)
// El vendedor registra lo que el cliente quiso comprar y no se vendio.
// ============================================

enum LostSaleReason {
  SIN_STOCK
  PRECIO_ALTO
  DESCONTINUADO
  PEDIDO_NO_RECIBIDO
}

model LostSale {
  id            String         @id @default(cuid())
  productId     String? // opcional: si es del catalogo
  product       Product?       @relation(fields: [productId], references: [id])
  productName   String // nombre (del catalogo o texto libre)
  productCode   String? // codigo si es del catalogo
  quantity      Float          @default(1)
  reason        LostSaleReason @default(SIN_STOCK)
  unitPriceUsd  Float          @default(0) // precio del momento (snapshot)
  unitPriceBs   Float          @default(0)
  estimatedUsd  Float          @default(0) // quantity * unitPriceUsd
  estimatedBs   Float          @default(0)
  stockAtMoment Float? // existencia del producto al momento (contexto)
  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id])
  notes         String?
  createdById   String
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
}

model CustomerAdvance {
  id            String                @id @default(cuid())
  customerId    String
  customer      Customer              @relation(fields: [customerId], references: [id])
  amountUsd     Float
  amountBs      Float
  exchangeRate  Float
  paidAmountUsd Float                 @default(0)
  paidAmountBs  Float                 @default(0)
  status        CustomerAdvanceStatus @default(AVAILABLE)
  reference     String?
  notes         String?
  methodId      String
  method        PaymentMethod         @relation(fields: [methodId], references: [id])
  cashSessionId String
  createdById   String
  createdBy     User                  @relation("AdvanceCreator", fields: [createdById], references: [id])
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model SupplierAdvance {
  id            String                @id @default(cuid())
  supplierId    String
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  amountUsd     Float
  amountBs      Float
  exchangeRate  Float
  paidAmountUsd Float                 @default(0)
  paidAmountBs  Float                 @default(0)
  status        SupplierAdvanceStatus @default(AVAILABLE)
  reference     String?
  notes         String?
  methodId      String
  method        PaymentMethod         @relation(fields: [methodId], references: [id])
  cashSessionId String
  createdById   String
  createdBy     User                  @relation("SupplierAdvanceCreator", fields: [createdById], references: [id])
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

// ============================================
// METODOS DE PAGO
// ============================================

model PaymentMethod {
  id                 String              @id @default(cuid())
  name               String              @unique
  isDivisa           Boolean             @default(false)
  isCash             Boolean             @default(false)
  createsReceivable  Boolean             @default(false)
  isActive           Boolean             @default(true)
  sortOrder          Int                 @default(0)
  fiscalCode         String?
  parentId           String?
  parent             PaymentMethod?      @relation("SubMethods", fields: [parentId], references: [id])
  children           PaymentMethod[]     @relation("SubMethods")
  payments           Payment[]
  receivablePayments ReceivablePayment[]
  payablePayments    PayablePayment[]
  receiptPayments    ReceiptPayment[]
  changePayments     Payment[]           @relation("ChangeMethod")
  expenses           Expense[]
  customerAdvances   CustomerAdvance[]
  supplierAdvances   SupplierAdvance[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

// ============================================
// SERIES (configuración de documentos fiscales)
// ============================================

model Serie {
  id                  String             @id @default(cuid())
  name                String             @unique
  prefix              String
  type                SerieType          @default(SALES)
  isFiscal            Boolean            @default(false)
  isVatExempt         Boolean            @default(false)
  lastNumber          Int                @default(0)  // DEPRECADO: contador compartido (reemplazado por contadores por tipo)
  lastInvoiceNumber    Int               @default(0)  // correlativo de facturas
  lastCreditNoteNumber Int               @default(0)  // correlativo de notas de credito (NCV/NCC)
  lastDebitNoteNumber  Int               @default(0)  // correlativo de notas de debito (NDV/NDC)
  lastReceivableNumber Int               @default(0)  // correlativo de CxC (documento de cuenta por cobrar)
  isActive            Boolean            @default(true)
  comPort             String?
  fiscalMachineSerial String?
  cashRegisterId      String?            @unique
  cashRegister        CashRegister?      @relation(fields: [cashRegisterId], references: [id])
  invoices            Invoice[]
  purchaseOrders      PurchaseOrder[]
  creditDebitNotes    CreditDebitNote[]
  retentionVouchers       RetentionVoucher[]
  islrRetentionVouchers   IslrRetentionVoucher[]
  receivables         Receivable[]       @relation("ReceivableSerie")
  payables            Payable[]          @relation("PayableSerie")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

// ============================================
// CAJAS
// ============================================

model CashRegister {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  isShared         Boolean           @default(false)
  isActive         Boolean           @default(true)
  serie            Serie?
  sessions         CashSession[]
  invoices         Invoice[]
  creditDebitNotes CreditDebitNote[]
  zReports         ZReport[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model CashSession {
  id                String         @id @default(cuid())
  cashRegisterId    String
  cashRegister      CashRegister   @relation(fields: [cashRegisterId], references: [id])
  openedById        String
  openedBy          User           @relation("SessionOpenedBy", fields: [openedById], references: [id])
  closedById        String?
  closedBy          User?          @relation("SessionClosedBy", fields: [closedById], references: [id])
  openingBalanceUsd Float          @default(0)
  openingBalanceBs  Float          @default(0)
  closingBalanceUsd Float?
  closingBalanceBs  Float?
  expectedUsd       Float?
  expectedBs        Float?
  differenceUsd     Float?
  differenceBs      Float?
  status            SessionStatus  @default(OPEN)
  notes             String?
  openedAt          DateTime       @default(now())
  closedAt          DateTime?
  cashMovements     CashMovement[]
  expenses          Expense[]      @relation("ExpenseSession")
}

model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id])
  type          CashMovementType
  amountUsd     Float            @default(0)
  amountBs      Float            @default(0)
  exchangeRate  Float            @default(0)
  currency      String // "USD" o "BS"
  reason        String
  isManual      Boolean          @default(true)
  expenseId     String?          @unique
  expense       Expense?         @relation(fields: [expenseId], references: [id])
  dynamicKeyId  String?
  createdById   String
  createdBy     User             @relation(fields: [createdById], references: [id])
  createdAt     DateTime         @default(now())
}

// ============================================
// FACTURACION
// ============================================

model Invoice {
  id                  String             @id @default(cuid())
  number              String?            @unique
  fiscalNumber        String?
  controlNumber       String?
  fiscalMachineSerial String?
  fiscalPrinted       Boolean            @default(false)
  serieId             String?
  serie               Serie?             @relation(fields: [serieId], references: [id])
  cashRegisterId      String
  cashRegister        CashRegister       @relation(fields: [cashRegisterId], references: [id])
  customerId          String?
  customer            Customer?          @relation(fields: [customerId], references: [id])
  status              InvoiceStatus      @default(PENDING)
  paymentType         InvoicePaymentType @default(CASH)
  type                InvoiceType        @default(SALE)
  subtotalUsd         Float              @default(0)
  ivaUsd              Float              @default(0)
  totalUsd            Float              @default(0)
  totalBs             Float              @default(0)
  exchangeRate        Float              @default(0)
  igtfUsd             Float              @default(0)
  igtfBs              Float              @default(0)
  subtotalBs          Float              @default(0)
  ivaBs               Float              @default(0)
  totalPaidUsd        Float              @default(0)
  changeBs            Float              @default(0)
  isCredit            Boolean            @default(false)
  creditDays          Int                @default(0)
  dueDate             DateTime?
  paidAt              DateTime?
  notes               String?
  items               InvoiceItem[]
  payments            Payment[]
  receivables         Receivable[]
  printJobs           PrintJob[]
  creditDebitNotes    CreditDebitNote[]
  salesBookEntries    SalesBookEntry[]
  customerIvaRetentions CustomerIvaRetention[]
  createdById         String
  sellerId            String?
  seller              Seller?            @relation(fields: [sellerId], references: [id])
  cashierId           String?
  cashier             User?              @relation("InvoiceCashier", fields: [cashierId], references: [id])
  lockedById          String?
  lockedAt            DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model InvoiceItem {
  id                    String  @id @default(cuid())
  invoiceId             String
  invoice               Invoice @relation(fields: [invoiceId], references: [id])
  productId             String
  productName           String
  quantity              Float
  unitPrice             Float
  ivaType               IvaType
  ivaAmount             Float
  totalUsd              Float
  unitPriceBs           Float   @default(0)
  ivaAmountBs           Float   @default(0)
  totalBs               Float   @default(0)
  unitPriceWithoutIva   Float   @default(0)
  unitPriceWithoutIvaBs Float   @default(0)
  discountPct           Float   @default(0)
  costUsd               Float   @default(0)
  costBs                Float   @default(0)
  priceOverridden       Boolean @default(false)
  returnedQty           Float   @default(0)
}

model Payment {
  id             String         @id @default(cuid())
  invoiceId      String
  invoice        Invoice        @relation(fields: [invoiceId], references: [id])
  methodId       String
  method         PaymentMethod  @relation(fields: [methodId], references: [id])
  amountUsd      Float
  amountBs       Float
  exchangeRate   Float
  reference      String?
  igtfUsd        Float          @default(0)
  igtfBs         Float          @default(0)
  changeAmountBs Float          @default(0)
  changeMethodId String?
  changeMethod   PaymentMethod? @relation("ChangeMethod", fields: [changeMethodId], references: [id])
  createdAt      DateTime       @default(now())
}

// ============================================
// CUENTAS POR COBRAR
// ============================================

model Receivable {
  id               String              @id @default(cuid())
  number           String?             @unique
  type             ReceivableType
  customerId       String?
  customer         Customer?           @relation(fields: [customerId], references: [id])
  platformName     String?
  reference        String?
  invoiceId        String?
  invoice          Invoice?            @relation(fields: [invoiceId], references: [id])
  documentNumber   String?
  description      String?
  amountUsd        Float
  amountBs         Float
  exchangeRate     Float
  dueDate          DateTime?
  status           ReceivableStatus    @default(PENDING)
  paidAmountUsd    Float               @default(0)
  paidAmountBs     Float               @default(0)
  paidAt           DateTime?
  notes            String?

  // Fiscal fields
  serieId          String?
  serie            Serie?              @relation("ReceivableSerie", fields: [serieId], references: [id])
  currency         String              @default("USD")
  originalDate     DateTime?
  receptionDate    DateTime?
  paymentTerms     String?

  // Tax breakdown (USD + Bs)
  exemptBaseUsd    Float               @default(0)
  exemptBaseBs     Float               @default(0)
  taxableBase8Usd  Float               @default(0)
  taxableBase8Bs   Float               @default(0)
  taxableBase16Usd Float               @default(0)
  taxableBase16Bs  Float               @default(0)
  taxableBase31Usd Float               @default(0)
  taxableBase31Bs  Float               @default(0)
  iva8Usd          Float               @default(0)
  iva8Bs           Float               @default(0)
  iva16Usd         Float               @default(0)
  iva16Bs          Float               @default(0)
  iva31Usd         Float               @default(0)
  iva31Bs          Float               @default(0)
  totalIvaUsd      Float               @default(0)
  totalIvaBs       Float               @default(0)
  igtfPct          Float               @default(0)
  igtfUsd          Float               @default(0)
  igtfBs           Float               @default(0)

  createdById      String?
  createdBy        User?               @relation("ReceivableCreator", fields: [createdById], references: [id])
  payments         ReceivablePayment[]
  receiptItems     ReceiptItem[]
  salesBookEntries SalesBookEntry[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model ReceivablePayment {
  id            String        @id @default(cuid())
  receivableId  String
  receivable    Receivable    @relation(fields: [receivableId], references: [id])
  receiptId     String?
  receipt       Receipt?      @relation(fields: [receiptId], references: [id])
  amountUsd     Float
  amountBs      Float
  exchangeRate  Float
  methodId      String
  method        PaymentMethod @relation(fields: [methodId], references: [id])
  reference     String?
  cashSessionId String?
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())
}

// ============================================
// CUENTAS POR PAGAR
// ============================================

model Payable {
  id                     String                @id @default(cuid())
  number                 String?               @unique
  supplierId             String
  supplier               Supplier              @relation(fields: [supplierId], references: [id])
  purchaseOrderId        String?
  purchaseOrder          PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  documentNumber         String?
  description            String?
  amountUsd              Float
  amountBs               Float
  exchangeRate           Float
  retentionUsd           Float                 @default(0)
  retentionBs            Float                 @default(0)
  netPayableUsd          Float
  netPayableBs           Float                 @default(0)
  dueDate                DateTime?
  status                 PayableStatus         @default(PENDING)
  paidAmountUsd          Float                 @default(0)
  paidAmountBs           Float                 @default(0)
  paidAt                 DateTime?
  notes                  String?

  // Fiscal fields
  serieId                String?
  serie                  Serie?                @relation("PayableSerie", fields: [serieId], references: [id])
  serieProveedor         String?               // serie alfanumerica de la factura del proveedor (ej. "A")
  controlFiscal          String?
  currency               String                @default("USD")
  originalDate           DateTime?
  receptionDate          DateTime?
  paymentTerms           String?

  // Tax breakdown (USD + Bs)
  exemptBaseUsd          Float                 @default(0)
  exemptBaseBs           Float                 @default(0)
  taxableBase8Usd        Float                 @default(0)
  taxableBase8Bs         Float                 @default(0)
  taxableBase16Usd       Float                 @default(0)
  taxableBase16Bs        Float                 @default(0)
  taxableBase31Usd       Float                 @default(0)
  taxableBase31Bs        Float                 @default(0)
  iva8Usd                Float                 @default(0)
  iva8Bs                 Float                 @default(0)
  iva16Usd               Float                 @default(0)
  iva16Bs                Float                 @default(0)
  iva31Usd               Float                 @default(0)
  iva31Bs                Float                 @default(0)
  totalIvaUsd            Float                 @default(0)
  totalIvaBs             Float                 @default(0)
  igtfPct                Float                 @default(0)
  igtfUsd                Float                 @default(0)
  igtfBs                 Float                 @default(0)

  createdById            String?
  createdBy              User?                 @relation("PayableCreator", fields: [createdById], references: [id])
  payments               PayablePayment[]
  receiptItems           ReceiptItem[]
  paymentScheduleItems   PaymentScheduleItem[]
  purchaseBookEntries    PurchaseBookEntry[]
  retentionVoucherLines  RetentionVoucherLine[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model PayablePayment {
  id           String        @id @default(cuid())
  payableId    String
  payable      Payable       @relation(fields: [payableId], references: [id])
  receiptId    String?
  receipt      Receipt?      @relation(fields: [receiptId], references: [id])
  amountUsd    Float
  amountBs     Float
  exchangeRate Float
  methodId     String
  method       PaymentMethod @relation(fields: [methodId], references: [id])
  reference    String?
  notes        String?
  createdById  String
  createdAt    DateTime      @default(now())
}

// ============================================
// RECIBOS DE COBRO / PAGO
// ============================================

model Receipt {
  id                 String              @id @default(cuid())
  number             String              @unique
  type               ReceiptType
  customerId         String?
  customer           Customer?           @relation(fields: [customerId], references: [id])
  supplierId         String?
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  status             ReceiptStatus       @default(DRAFT)
  totalUsd           Float               @default(0)
  totalBsHistoric    Float               @default(0)
  totalBsToday       Float               @default(0)
  exchangeRate       Float               @default(0)
  differentialBs     Float               @default(0)
  hasDifferential    Boolean             @default(false)
  notes              String?
  items              ReceiptItem[]
  payments           ReceiptPayment[]
  receivablePayments ReceivablePayment[]
  payablePayments    PayablePayment[]
  cashSessionId      String?
  createdById        String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model ReceiptItem {
  id                String           @id @default(cuid())
  receiptId         String
  receipt           Receipt          @relation(fields: [receiptId], references: [id])
  itemType          ReceiptItemType
  receivableId      String?
  receivable        Receivable?      @relation(fields: [receivableId], references: [id])
  payableId         String?
  payable           Payable?         @relation(fields: [payableId], references: [id])
  creditDebitNoteId String?
  creditDebitNote   CreditDebitNote? @relation(fields: [creditDebitNoteId], references: [id])
  ivaRetentionId    String?
  ivaRetention      IvaRetention?    @relation(fields: [ivaRetentionId], references: [id])
  customerIvaRetentionId String?
  customerIvaRetention   CustomerIvaRetention? @relation(fields: [customerIvaRetentionId], references: [id])
  description       String
  amountUsd         Float            @default(0)
  amountBsHistoric  Float            @default(0)
  amountBsToday     Float            @default(0)
  differentialBs    Float            @default(0)
  sign              Int              @default(1)
}

model IvaRetention {
  id              String        @id @default(cuid())
  number          String        @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  ivaBaseUsd      Float
  ivaBaseBs       Float         @default(0)
  retentionPct    Float
  retentionUsd    Float
  retentionBs     Float         @default(0)
  exchangeRate    Float
  appliedAt       DateTime?
  createdById     String
  receiptItems    ReceiptItem[]
  createdAt       DateTime      @default(now())
}

model ReceiptPayment {
  id           String        @id @default(cuid())
  receiptId    String
  receipt      Receipt       @relation(fields: [receiptId], references: [id])
  methodId     String
  method       PaymentMethod @relation(fields: [methodId], references: [id])
  amountUsd    Float         @default(0)
  amountBs     Float         @default(0)
  exchangeRate Float         @default(0)
  reference    String?
  createdAt    DateTime      @default(now())
}

// ============================================
// AJUSTE MASIVO DE PRECIOS
// ============================================

model PriceAdjustmentLog {
  id               String   @id @default(cuid())
  filters          Json
  adjustmentType   String
  gananciaPct      Float?
  gananciaMayorPct Float?
  productsAffected Int
  createdById      String
  createdAt        DateTime @default(now())
}

// ============================================
// TRABAJOS DE IMPRESION
// ============================================

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum PrintStatus {
  PENDING
  PRINTING
  PRINTED
  FAILED
}

model PrintJob {
  id            String      @id @default(cuid())
  invoiceId     String
  invoice       Invoice     @relation(fields: [invoiceId], references: [id])
  printAreaId   String
  printArea     PrintArea   @relation(fields: [printAreaId], references: [id])
  status        PrintStatus @default(PENDING)
  items         Json
  isReprint     Boolean     @default(false)
  reprintOfId   String?
  failureReason String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ============================================
// COTIZACIONES
// ============================================

model Quotation {
  id                   String          @id @default(cuid())
  number               String          @unique
  customerId           String?
  customer             Customer?       @relation(fields: [customerId], references: [id])
  status               QuotationStatus @default(DRAFT)
  subtotalUsd          Float           @default(0)
  subtotalBs           Float           @default(0)
  ivaUsd               Float           @default(0)
  ivaBs                Float           @default(0)
  totalUsd             Float           @default(0)
  totalBs              Float           @default(0)
  exchangeRate         Float           @default(0)
  notes                String?
  expiresAt            DateTime?
  convertedToInvoiceId String?
  items                QuotationItem[]
  createdById          String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model QuotationItem {
  id           String    @id @default(cuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  productCode  String
  quantity     Float
  unitPriceUsd Float
  unitPriceBs  Float     @default(0)
  ivaType      IvaType
  ivaAmount    Float
  ivaAmountBs  Float     @default(0)
  totalUsd     Float
  totalBs      Float     @default(0)
}

// ============================================
// NOTAS DE CREDITO / DEBITO
// ============================================

model CreditDebitNote {
  id                   String                @id @default(cuid())
  number               String                @unique
  type                 NoteType
  origin               NoteOrigin
  status               NoteStatus            @default(DRAFT)
  invoiceId            String?
  invoice              Invoice?              @relation(fields: [invoiceId], references: [id])
  serieId              String?
  serie                Serie?                @relation(fields: [serieId], references: [id])
  cashRegisterId       String?
  cashRegister         CashRegister?         @relation(fields: [cashRegisterId], references: [id])
  fiscalNumber         String?
  machineSerial        String?
  fiscalPrinted        Boolean               @default(false)
  purchaseOrderId      String?
  purchaseOrder        PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  subtotalUsd          Float                 @default(0)
  ivaUsd               Float                 @default(0)
  igtfUsd              Float                 @default(0)
  igtfBs               Float                 @default(0)
  totalUsd             Float                 @default(0)
  subtotalBs           Float                 @default(0)
  ivaBs                Float                 @default(0)
  totalBs              Float                 @default(0)
  exchangeRate         Float                 @default(0)
  manualAmountUsd      Float?
  manualPct            Float?
  documentDate         DateTime?
  supplierDocNumber    String?   // N° de la nota que da el proveedor (NCC/NDC de compra, para el libro)
  notes                String?
  paidAmountUsd        Float                 @default(0)
  appliedAt            DateTime?
  items                CreditDebitNoteItem[]
  receiptItems         ReceiptItem[]
  paymentScheduleItems PaymentScheduleItem[]
  createdById          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model CreditDebitNoteItem {
  id           String          @id @default(cuid())
  noteId       String
  note         CreditDebitNote @relation(fields: [noteId], references: [id])
  productId    String?
  productName  String
  productCode  String
  quantity     Float
  unitPriceUsd Float
  unitPriceBs  Float
  ivaType      IvaType
  ivaAmount    Float
  ivaAmountBs  Float
  totalUsd     Float
  totalBs      Float
}

// ============================================
// PROGRAMACION DE PAGOS
// ============================================

model PaymentSchedule {
  id             String                @id @default(cuid())
  number         String                @unique
  title          String
  status         PaymentScheduleStatus @default(DRAFT)
  budgetUsd      Float?
  budgetBs       Float?
  budgetCurrency String? // "USD" o "Bs" — moneda elegida por el usuario
  totalUsd       Float                 @default(0)
  totalBs        Float                 @default(0)
  exchangeRate   Float                 @default(0)
  notes          String?
  items          PaymentScheduleItem[]
  createdById    String
  createdBy      User                  @relation(fields: [createdById], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model PaymentScheduleItem {
  id                String           @id @default(cuid())
  scheduleId        String
  schedule          PaymentSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  payableId         String?
  payable           Payable?         @relation(fields: [payableId], references: [id])
  creditDebitNoteId String?
  creditDebitNote   CreditDebitNote? @relation(fields: [creditDebitNoteId], references: [id])
  supplierName      String
  description       String
  totalAmountUsd    Float
  totalAmountBs     Float
  plannedAmountUsd  Float
  plannedAmountBs   Float
  isPaid            Boolean          @default(false)
  createdAt         DateTime         @default(now())
}

// ============================================
// GASTOS
// ============================================

model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  expenses    Expense[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Expense {
  id            String          @id @default(cuid())
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  description   String
  reference     String?
  amountUsd     Float
  amountBs      Float
  exchangeRate  Float
  date          DateTime
  notes         String?
  cashSessionId String?
  cashSession   CashSession?    @relation("ExpenseSession", fields: [cashSessionId], references: [id])
  methodId      String?
  method        PaymentMethod?  @relation(fields: [methodId], references: [id])
  cashMovement  CashMovement?
  createdById   String
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ============================================
// LIBRO DE COMPRAS
// ============================================

model PurchaseBookEntry {
  id                     String            @id @default(cuid())
  purchaseOrderId        String?
  purchaseOrder          PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  payableId              String?
  payable                Payable?          @relation(fields: [payableId], references: [id])
  entryDate              DateTime          // periodo: cuando se declara/aparece en el libro (filtro). En CxP = fecha recepcion
  documentDate           DateTime?         // fecha que se MUESTRA en el reporte (fecha original del proveedor). Si null, se usa entryDate
  supplierControlNumber  String?
  supplierInvoiceNumber  String?
  supplierSerie          String?   // serie alfanumerica de la factura del proveedor (ej. "A")
  supplierName           String
  supplierRif            String
  exemptAmountBs         Float             @default(0)
  taxableBaseBs          Float             @default(0)
  ivaAmountBs            Float             @default(0)
  retentionVoucherNumber String?
  retentionAmountBs      Float             @default(0)
  totalBs                Float             @default(0)
  isManual               Boolean           @default(false)
  documentType           String            @default("FACTURA")
  affectedDocNumber      String?
  creditDebitNoteId      String?           // nota (NCC/NDC) que genero esta linea, para poder editarla luego
  isRetentionLine            Boolean                @default(false)
  retentionVoucherId         String?
  retentionVoucher           RetentionVoucher?      @relation(fields: [retentionVoucherId], references: [id])
  isIslrRetentionLine        Boolean                @default(false)
  islrRetentionAmountBs      Float                  @default(0)
  islrRetentionVoucherId     String?
  islrRetentionVoucher       IslrRetentionVoucher?  @relation(fields: [islrRetentionVoucherId], references: [id])
  islrRetentionVoucherNumber String?
  notes                      String?
  createdById                String
  createdBy                  User              @relation("PurchaseBookEntries", fields: [createdById], references: [id])
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
}

// ============================================
// LIBRO DE VENTAS
// ============================================

model SalesBookEntry {
  id              String      @id @default(cuid())
  invoiceId       String?
  invoice         Invoice?    @relation(fields: [invoiceId], references: [id])
  receivableId    String?
  receivable      Receivable? @relation(fields: [receivableId], references: [id])
  entryDate       DateTime
  invoiceNumber   String
  controlNumber   String?
  customerName    String
  customerRif     String?
  exemptAmountBs  Float       @default(0)
  taxableBaseBs   Float       @default(0)
  ivaAmountBs     Float       @default(0)
  igtfAmountBs    Float       @default(0)
  totalBs         Float       @default(0)
  isManual        Boolean     @default(false)
  isRetentionLine Boolean     @default(false)
  documentType         String @default("FACTURA")
  affectedDocNumber    String?
  retentionAmountBs    Float  @default(0)
  retentionVoucherNumber String?
  customerIvaRetention CustomerIvaRetention?
  notes           String?
  createdById     String
  createdBy       User        @relation("SalesBookEntries", fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ============================================
// COMPROBANTES DE RETENCION IVA
// ============================================

model RetentionVoucher {
  id                 String                 @id @default(cuid())
  number             String                 @unique
  supplierId         String
  supplier           Supplier               @relation(fields: [supplierId], references: [id])
  serieId            String?
  serie              Serie?                 @relation(fields: [serieId], references: [id])
  status             RetentionStatus        @default(PENDING)
  issueDate          DateTime?
  retentionPct       Float                  @default(75)
  retentionAmountUsd Float                  @default(0)
  retentionAmountBs  Float                  @default(0)
  exchangeRate       Float                  @default(0)
  notes              String?
  lines              RetentionVoucherLine[]
  bookEntries        PurchaseBookEntry[]
  createdById        String
  createdBy          User                   @relation("RetentionVoucherCreator", fields: [createdById], references: [id])
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model RetentionVoucherLine {
  id                    String           @id @default(cuid())
  retentionVoucherId    String
  retentionVoucher      RetentionVoucher @relation(fields: [retentionVoucherId], references: [id], onDelete: Cascade)
  purchaseOrderId       String?
  purchaseOrder         PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  payableId             String?
  payable               Payable?         @relation(fields: [payableId], references: [id])
  supplierInvoiceNumber String?
  supplierControlNumber String?
  invoiceDate           DateTime?
  invoiceTotalUsd       Float            @default(0)
  invoiceTotalBs        Float            @default(0)
  taxableBaseUsd        Float            @default(0)
  taxableBaseBs         Float            @default(0)
  ivaAmountUsd          Float            @default(0)
  ivaAmountBs           Float            @default(0)
  retentionPct          Float            @default(75)
  retentionAmountUsd    Float            @default(0)
  retentionAmountBs     Float            @default(0)
  exchangeRate          Float            @default(0)
  isManual              Boolean          @default(false)
  createdAt             DateTime         @default(now())
}

// ============================================
// RETENCIONES DE IVA SUFRIDAS (clientes contribuyentes especiales)
// ============================================

model CustomerIvaRetention {
  id                String          @id @default(cuid())
  number            String          @unique
  invoiceId         String
  invoice           Invoice         @relation(fields: [invoiceId], references: [id])
  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id])
  taxableBaseUsd    Float           @default(0)
  taxableBaseBs     Float           @default(0)
  ivaAmountUsd      Float           @default(0)
  ivaAmountBs       Float           @default(0)
  retentionPct      Float           @default(75)
  retentionUsd      Float           @default(0)
  retentionBs       Float           @default(0)
  exchangeRate      Float           @default(0)
  voucherNumber     String?
  voucherDate       DateTime?
  voucherReceivedAt DateTime?
  appliedAt         DateTime?
  cancelledAt       DateTime?
  notes             String?
  salesBookEntryId  String?         @unique
  salesBookEntry    SalesBookEntry? @relation(fields: [salesBookEntryId], references: [id])
  receiptItems      ReceiptItem[]
  createdById       String
  createdBy         User            @relation("CustomerIvaRetentionCreator", fields: [createdById], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

// ============================================
// REPORTES Z (CIERRES FISCALES)
// ============================================

model ZReport {
  id                    String        @id @default(cuid())
  zNumber               Int
  reportDate            DateTime
  machineSerial         String

  cashRegisterId        String?
  cashRegister          CashRegister? @relation(fields: [cashRegisterId], references: [id])

  // Ventas
  salesExemptBs         Float         @default(0)
  salesTaxBase1Bs       Float         @default(0)
  salesTax1Bs           Float         @default(0)
  salesTaxBase2Bs       Float         @default(0)
  salesTax2Bs           Float         @default(0)
  salesTaxBase3Bs       Float         @default(0)
  salesTax3Bs           Float         @default(0)

  // Notas de Crédito
  ncExemptBs            Float         @default(0)
  ncTaxBase1Bs          Float         @default(0)
  ncTax1Bs              Float         @default(0)
  ncTaxBase2Bs          Float         @default(0)
  ncTax2Bs              Float         @default(0)
  ncTaxBase3Bs          Float         @default(0)
  ncTax3Bs              Float         @default(0)

  // Notas de Débito (solo Family A)
  ndExemptBs            Float         @default(0)
  ndTaxBase1Bs          Float         @default(0)
  ndTax1Bs              Float         @default(0)
  ndTaxBase2Bs          Float         @default(0)
  ndTax2Bs              Float         @default(0)
  ndTaxBase3Bs          Float         @default(0)
  ndTax3Bs              Float         @default(0)

  // IGTF Ventas
  igtfSalesBaseBs       Float         @default(0)
  igtfSalesTaxBs        Float         @default(0)
  // IGTF NC
  igtfNcBaseBs          Float         @default(0)
  igtfNcTaxBs           Float         @default(0)
  // IGTF ND
  igtfNdBaseBs          Float         @default(0)
  igtfNdTaxBs           Float         @default(0)

  // Rangos de documentos
  lastInvoiceNumber     String?
  firstInvoiceNumber    String?
  invoiceCount          Int           @default(0)
  lastCreditNoteNumber  String?
  firstCreditNoteNumber String?
  creditNoteCount       Int           @default(0)
  lastDebitNoteNumber   String?
  firstDebitNoteNumber  String?
  debitNoteCount        Int           @default(0)

  // Metadata
  isManual              Boolean       @default(false)
  printerFamily         String?
  rawResponse           String?       @db.Text
  notes                 String?

  createdById           String
  createdBy             User          @relation("ZReportCreator", fields: [createdById], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([zNumber, machineSerial])
}

// ============================================
// TIPOS DE RETENCION ISLR (Decreto 1808)
// ============================================

model IslrRetentionType {
  id                  String                    @id @default(cuid())
  codigo              Int                       @unique
  descripcion         String
  baseImponiblePct    Float                     @default(100)
  retentionPct        Float
  sustraendoUt        Float                     @default(0)
  forPersonaJuridica  Boolean                   @default(false)
  forPersonaResidente Boolean                   @default(false)
  isActive            Boolean                   @default(true)
  voucherLines        IslrRetentionVoucherLine[]
  suppliers           Supplier[]                @relation("SupplierIslrConcept")
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
}

// ============================================
// COMPROBANTES DE RETENCION ISLR
// ============================================

model IslrRetentionVoucher {
  id                 String                       @id @default(cuid())
  number             String                       @unique
  supplierId         String
  supplier           Supplier                     @relation(fields: [supplierId], references: [id])
  serieId            String?
  serie              Serie?                       @relation(fields: [serieId], references: [id])
  status             RetentionStatus              @default(PENDING)
  issueDate          DateTime?
  retentionAmountUsd Float                        @default(0)
  retentionAmountBs  Float                        @default(0)
  exchangeRate       Float                        @default(0)
  unidadTributaria   Float                        @default(43)
  notes              String?
  lines              IslrRetentionVoucherLine[]
  bookEntries        PurchaseBookEntry[]
  createdById        String
  createdBy          User                         @relation("IslrRetentionVoucherCreator", fields: [createdById], references: [id])
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
}

model IslrRetentionVoucherLine {
  id                       String               @id @default(cuid())
  islrRetentionVoucherId   String
  islrRetentionVoucher     IslrRetentionVoucher  @relation(fields: [islrRetentionVoucherId], references: [id], onDelete: Cascade)
  purchaseOrderId          String?
  purchaseOrder            PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  islrRetentionTypeId      String
  islrRetentionType        IslrRetentionType     @relation(fields: [islrRetentionTypeId], references: [id])
  supplierInvoiceNumber    String?
  supplierControlNumber    String?
  invoiceDate              DateTime?
  invoiceTotalUsd          Float                 @default(0)
  invoiceTotalBs           Float                 @default(0)
  taxableBaseUsd           Float                 @default(0)
  taxableBaseBs            Float                 @default(0)
  baseImponiblePct         Float                 @default(100)
  retentionPct             Float                 @default(0)
  sustraendoUt             Float                 @default(0)
  sustraendoBs             Float                 @default(0)
  retentionAmountUsd       Float                 @default(0)
  retentionAmountBs        Float                 @default(0)
  exchangeRate             Float                 @default(0)
  isManual                 Boolean               @default(false)
  createdAt                DateTime              @default(now())
}
